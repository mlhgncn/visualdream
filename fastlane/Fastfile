default_platform(:ios)

platform :ios do
  desc "Upload existing IPA to TestFlight using App Store Connect API key"
  lane :ci_upload do
    app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_PRIVATE_KEY']
    )

    # Allow overriding via ENV or auto-detect an .ipa in the repo
    ipa_path = ENV['IPA_PATH']
    if ipa_path.nil? || ipa_path.strip.empty?
      possible = Dir.glob("**/*.ipa").reject { |p| p.include?("Pods") }
      ipa_path = possible.first
    end

    unless ipa_path && File.exist?(ipa_path)
      UI.user_error!("IPA not found. Set ENV['IPA_PATH'] or ensure an .ipa exists in the repo")
    end

    upload_to_testflight(
      ipa: ipa_path,
      skip_waiting_for_build_processing: false,
      force: true
    )
  end

  desc "CI: build archive using match and gym"
  lane :ci_build do
    UI.message("Starting ci_build lane: fetching certificates with match")

    match_git = ENV['MATCH_GIT_URL']
    match_password = ENV['MATCH_PASSWORD']
    if match_git.nil? || match_git.strip.empty?
      UI.user_error!("MATCH_GIT_URL not set. Provide the match git repo URL in MATCH_GIT_URL secret.")
    end

    ENV['MATCH_PASSWORD'] = match_password if match_password

    match(type: "appstore", readonly: true, git_url: match_git)

    scheme = ENV['SCHEME']
    if scheme.nil? || scheme.strip.empty?
      UI.user_error!("SCHEME not set. Set the Xcode scheme name in ENV['SCHEME'].")
    end

    ipa = nil
    if ENV['WORKSPACE'] && !ENV['WORKSPACE'].strip.empty?
      ipa = gym(
        workspace: ENV['WORKSPACE'],
        scheme: scheme,
        export_method: 'app-store',
        output_directory: 'client/build',
        output_name: 'app.ipa'
      )
    else
      project_path = ENV['PROJECT'] || "client/ios/#{scheme}.xcodeproj"
      ipa = gym(
        project: project_path,
        scheme: scheme,
        export_method: 'app-store',
        output_directory: 'client/build',
        output_name: 'app.ipa'
      )
    end

    ENV['IPA_PATH'] = ipa
    UI.message("Built IPA at #{ipa}")
  end
end
