default_platform(:ios)

platform :ios do
  desc "Upload existing IPA to TestFlight using App Store Connect API key"
  lane :ci_upload do
    app_store_connect_api_key(
      key_id: ENV['ASC_KEY_ID'],
      issuer_id: ENV['ASC_ISSUER_ID'],
      key_content: ENV['ASC_PRIVATE_KEY']
    )

    # Allow overriding via ENV or auto-detect an .ipa in the repo
    ipa_path = ENV['IPA_PATH']
    if ipa_path.nil? || ipa_path.strip.empty?
      possible = Dir.glob("**/*.ipa").reject { |p| p.include?("Pods") }
      ipa_path = possible.first
    end

    unless ipa_path && File.exist?(ipa_path)
      UI.user_error!("IPA not found. Set ENV['IPA_PATH'] or ensure an .ipa exists in the repo")
    end

    upload_to_testflight(
      ipa: ipa_path,
      skip_waiting_for_build_processing: false,
      force: true
    )
  end
end
