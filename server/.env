# .env for ruya-gemini-server
# DO NOT COMMIT this file to version control — contains secrets.

# Server port
PORT=3001

# Gemini image API (preferred)
GEMINI_IMAGE_API_KEY=***REMOVED***
GEMINI_IMAGE_URL=https://upload.wikimedia.org/wikipedia/commons/thumb/3/3a/Cat03.jpg/1200px-Cat03.jpg

# Alternative keys (server falls back to these names)
GEMINI_API_KEY=***REMOVED***
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
MOCK_IMAGE_URL=https://via.placeholder.com/600.png
MOCK_GENERATE=true
